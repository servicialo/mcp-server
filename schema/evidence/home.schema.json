{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://servicialo.com/schema/evidence/home.schema.json",
  "title": "Servicialo Evidence — Home Services Vertical",
  "description": "Evidence requirements for the home services (hogar) vertical. Defined in PROTOCOL.md §9 / whitepaper §9.2.",
  "type": "object",
  "required": ["vertical", "evidence"],

  "x-resolution-rule": {
    "description": "If before/after photos exist with valid metadata (timestamp + GPS) AND completion checklist is fully checked, service is verified as delivered. If client signature is missing, escalate to dispute.",
    "required_for_resolution": ["photo_before", "photo_after", "completion_checklist", "client_signature"],
    "escalate_if_missing": ["client_signature"]
  },

  "properties": {
    "vertical": {
      "type": "string",
      "const": "home"
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "base.schema.json"
      }
    }
  },

  "$defs": {
    "evidence_types": {
      "description": "Catalog of evidence types for the home services vertical.",
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/photo_before" },
          { "$ref": "#/$defs/photo_after" },
          { "$ref": "#/$defs/completion_checklist" },
          { "$ref": "#/$defs/client_signature" }
        ]
      }
    },

    "photo_before": {
      "type": "object",
      "description": "Photo of initial state with timestamp and GPS metadata.",
      "x-auto-captured": false,
      "x-required-for-resolution": true,
      "x-default-sensitivity": "public",
      "properties": {
        "type": { "const": "photo" },
        "method": { "const": "manual" },
        "data": {
          "allOf": [
            { "$ref": "base.schema.json#/$defs/photo_data" },
            {
              "properties": {
                "label": { "const": "before" },
                "metadata": {
                  "required": ["latitude", "longitude", "taken_at"],
                  "description": "GPS and timestamp metadata are required for before photos."
                }
              },
              "required": ["label", "metadata"]
            }
          ]
        }
      },
      "required": ["type", "captured_at", "actor", "data"]
    },

    "photo_after": {
      "type": "object",
      "description": "Photo of final state with timestamp and GPS metadata.",
      "x-auto-captured": false,
      "x-required-for-resolution": true,
      "x-default-sensitivity": "public",
      "properties": {
        "type": { "const": "photo" },
        "method": { "const": "manual" },
        "data": {
          "allOf": [
            { "$ref": "base.schema.json#/$defs/photo_data" },
            {
              "properties": {
                "label": { "const": "after" },
                "metadata": {
                  "required": ["latitude", "longitude", "taken_at"],
                  "description": "GPS and timestamp metadata are required for after photos."
                }
              },
              "required": ["label", "metadata"]
            }
          ]
        }
      },
      "required": ["type", "captured_at", "actor", "data"]
    },

    "completion_checklist": {
      "type": "object",
      "description": "Agreed tasks marked as completed.",
      "x-auto-captured": false,
      "x-required-for-resolution": true,
      "x-default-sensitivity": "internal",
      "properties": {
        "type": { "const": "document" },
        "method": { "const": "manual" },
        "data": {
          "type": "object",
          "required": ["document_type", "checklist"],
          "properties": {
            "document_type": { "const": "completion_checklist" },
            "checklist": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["task", "completed"],
                "properties": {
                  "task": { "type": "string", "description": "Agreed task description." },
                  "completed": { "type": "boolean" }
                }
              },
              "minItems": 1
            },
            "all_completed": {
              "type": "boolean",
              "description": "True if all checklist items are completed. Computed field."
            }
          }
        }
      },
      "required": ["type", "captured_at", "actor", "data"]
    },

    "client_signature": {
      "type": "object",
      "description": "Digital signature from client confirming service receipt.",
      "x-auto-captured": false,
      "x-required-for-resolution": true,
      "x-default-sensitivity": "confidential",
      "properties": {
        "type": { "const": "signature" },
        "method": { "const": "manual" },
        "data": {
          "allOf": [
            { "$ref": "base.schema.json#/$defs/signature_data" },
            {
              "properties": {
                "signer_role": { "const": "client" }
              }
            }
          ]
        }
      },
      "required": ["type", "captured_at", "actor", "data"]
    }
  }
}
