SERVICIALO_API_KEY=          # API key de organizacion (requerida para tools autenticadas)
SERVICIALO_ORG_ID=           # Slug de la organizacion (ej: clinica-demo)
SERVICIALO_BASE_URL=https://api.servicialo.com
# Para desarrollo local: http://localhost:3000
# Para Coordinalo: https://coordinalo.com
SERVICIALO_ADAPTER=coordinalo
# "coordinalo" (default) — paths propietarios de Coordinalo
# "http" — paths /v1/* para backends propios compatibles con el protocolo

# --- Node identity (optional) ---
# Set these to identify your implementation and apply for verified status.
# If not set, your node remains fully anonymous — no change in behavior.
# See: https://servicialo.com/implementors
SERVICIALO_IMPL_NAME=        # Name of your implementation (e.g. "MyClinic Platform")
SERVICIALO_IMPL_URL=         # Your website or repo URL
SERVICIALO_IMPL_CONTACT=     # Contact email (hashed, never displayed publicly)
