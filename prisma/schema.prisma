generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["servicialo"]
}

// ── Organization ──

model Organization {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  description   String    @default("")
  vertical      String    @default("")
  location      String    @default("")
  country       String    @default("")
  contactEmail  String    @default("")
  discoverable  Boolean   @default(false)
  claimedAt     DateTime?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Resolver endpoints (portability: change these, keep the slug)
  mcpUrl        String    @default("")
  restUrl       String    @default("")
  healthUrl     String    @default("")

  // Trust (passive, accumulated)
  trustScore    Int       @default(0)
  trustLevel    String    @default("unverified")
  lastSeen      DateTime?
  registeredAt  DateTime?

  // Capabilities (probed by resolver)
  capServices       String    @default("unverified")   // "unverified" | "verified" | "empty"
  capServicesCount  Int       @default(0)
  capServicesAt     DateTime?
  capAvailability   String    @default("unverified")   // "unverified" | "verified" | "unavailable"
  capAvailabilityAt DateTime?
  capBooking        String    @default("unverified")   // "unverified" | "verified"
  capBookingAt      DateTime?

  services      Service[]
  providers     Provider[]

  @@index([country, slug])
  @@schema("servicialo")
}

// ── Provider ──

model Provider {
  id             String        @id @default(cuid())
  name           String
  email          String?
  isActive       Boolean       @default(true)

  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])

  serviceProviders ServiceProvider[]
  appointments     Appointment[]
  availability     ProviderAvailability[]

  createdAt      DateTime      @default(now())

  @@schema("servicialo")
}

// ── Service ──

model Service {
  id              String    @id @default(cuid())
  name            String
  description     String    @default("")
  durationMinutes Int       @default(60)
  priceAmount     Int?
  priceCurrency   String?
  isActive        Boolean   @default(true)

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  serviceProviders ServiceProvider[]
  appointments     Appointment[]

  createdAt       DateTime  @default(now())

  @@schema("servicialo")
}

// ── Many-to-many: Service <-> Provider ──

model ServiceProvider {
  id         String   @id @default(cuid())
  serviceId  String
  providerId String

  service    Service  @relation(fields: [serviceId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])

  @@unique([serviceId, providerId])
  @@schema("servicialo")
}

// ── Provider Availability (weekly schedule) ──

model ProviderAvailability {
  id         String @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  dayOfWeek  Int    // ISO weekday: 1=Mon … 7=Sun
  startTime  String // "HH:MM" in provider's timezone
  endTime    String // "HH:MM" in provider's timezone
  timezone   String @default("America/Santiago")

  @@unique([providerId, dayOfWeek, startTime])
  @@schema("servicialo")
}

// ── Appointment (booking) ──

model Appointment {
  id             String    @id @default(cuid())
  start          DateTime
  end            DateTime
  status         String    @default("confirmed")
  notes          String    @default("")
  bookedByAgent  Boolean   @default(false)

  requesterName  String
  requesterEmail String

  serviceId      String
  service        Service   @relation(fields: [serviceId], references: [id])

  providerId     String
  provider       Provider  @relation(fields: [providerId], references: [id])

  createdAt      DateTime  @default(now())

  @@unique([providerId, start])
  @@schema("servicialo")
}
